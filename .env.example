# --- NORTHBRIDGE ANALYTICS ENVIRONMENT TEMPLATE ---
# Copy this file to .env and fill in the values for your environment.

# --- API CONFIG ---
# The base URL for the Northbridge MySQL-backed REST API
BASE_URL="https://api.northbridge.analytics/v1/"

# How often the app should attempt a background sync (in minutes)
SYNC_INTERVAL_MINUTES=15

# --- AUTHENTICATION ---
# The header used for JWT or Bearer token passing
AUTH_TOKEN_HEADER="Authorization"

# Firebase Cloud Messaging Sender ID (for push notification alerts)
FCM_SENDER_ID="your-fcm-id-here"

# --- LOCAL DATABASE ---
# The filename for the local Room SQLite database
LOCAL_DB_NAME="northbridge_secure.db"

# Optional: Passphrase for SQLCipher encryption (if enabled in build)
# DATABASE_ENCRYPTION_KEY="your-secure-passphrase"

# --- LOGGING & DEBUG ---
# Set to 'true' to enable verbose HTTP logging in debug builds
ENABLE_HTTP_LOGGING=true
